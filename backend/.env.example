# --- VerityGate configuration ---
# Everything has sane defaults so the app runs with NO config (mock provider).

APP_NAME=VerityGate
ENVIRONMENT=development

# Database (SQLite by default; switch to postgresql+psycopg:// for prod)
DATABASE_URL=sqlite:///./veritygate.db

# Default provider routing strategy: cost | latency | quality | risk
ROUTING_STRATEGY=risk

# Provider API keys (optional). If absent, the mock provider is used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Baseline risk thresholds (evaluation score below which a gate trips). 0..1
# Per-domain policy-as-code in app/governance/policies/*.yaml overrides these.
MIN_FAITHFULNESS=0.6
MIN_CITATION_COVERAGE=0.5
MIN_POLICY_SCORE=0.7

# LLM-as-judge: when true (and a provider key is set), an LLM scores
# faithfulness/policy. Falls back to the offline heuristic automatically.
USE_LLM_JUDGE=false
JUDGE_MODEL=gpt-4o-mini

# Semantic cache similarity threshold (cosine). 0..1
CACHE_SIMILARITY_THRESHOLD=0.92
